{% extends 'base.html.twig' %}

{% block title %}Mes Photos Privées{% endblock %}

{% block body %}
<nav>
    {% if app.user %}
        <span>Bienvenue, {{ app.user.email }}</span>
        <button id="addMediaBtn">Ajouter un post</button>
        <a href="{{ path('app_logout') }}">Déconnexion</a>
    {% else %}
        <a href="{{ path('app_home') }}">Accueil</a>
    {% endif %}
</nav>

{% for message in app.flashes('success') %}
    <div class="flash-success">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="flash-error">{{ message }}</div>
{% endfor %}

{% if photos is empty %}
    <p>Vous n'avez aucune photo privée pour l'instant.</p>
{% else %}
    <div class="gallery">
        {% for photo in photos %}
            <div class="media-item">
                <img src="{{ asset('uploads/photos/' ~ photo.photoUrl) }}" alt="photo">
                <p>{{ photo.description }}</p>
                <small>{{ photo.localisation }}</small>
                <span class="label-prive">Privé</span>

                <!-- Dépliant infos -->
                <div class="photo-info" style="display:none; text-align:left; margin-top:5px;">
                    <p><strong>Description :</strong> {{ photo.description }}</p>
                    <p><strong>Localisation :</strong> {{ photo.localisation ?: 'Non renseignée' }}</p>
                    <p><strong>Date de prise :</strong> 
                        {% if photo.datePrise %}
                            {{ photo.datePrise|date('d/m/Y') }}
                        {% else %}
                            Non renseignée
                        {% endif %}
                    </p>
                    <p><strong>Thème :</strong> 
                        {% if photo.themes|length > 0 %}
                            {{ photo.themes|first.nom }}
                        {% else %}
                            Aucun
                        {% endif %}
                    </p>
                </div>

                <!-- Bouton pour déplier -->
                <button class="toggle-info">Voir détails</button>
            </div>
        {% endfor %}
    </div>
{% endif %}

<!-- MODAL AJOUT PHOTO -->
<div id="addMediaModal" class="modal">
    <div class="modal-content">
        <h2>Ajouter une nouvelle photo</h2>
        <form action="{{ path('app_upload_photo') }}" method="POST" enctype="multipart/form-data">
            <label>Photo</label>
            <input type="file" name="photo_file" accept="image/*" required>

            <label>Description</label>
            <input type="text" name="description" required>

            <label>Localisation</label>
            <input type="text" name="localisation">

            <label>Date de prise</label>
            <input type="date" name="date_prise">

            <label>Thème</label>
            <select name="theme_id" required>
                <option value="">-- Choisir un thème --</option>
                {% for theme in themes %}
                    <option value="{{ theme.id }}">{{ theme.nom }}</option>
                {% endfor %}
            </select>

            <label>
                <input type="checkbox" name="public">
                Publier en public
            </label>

            <br><br>
            <button type="submit">Publier</button>
        </form>

        <br>
        <button id="closeModal">Fermer</button>
    </div>
</div>

<script>
const modal = document.getElementById('addMediaModal');
const btn = document.getElementById('addMediaBtn');
const close = document.getElementById('closeModal');

btn?.addEventListener('click', () => modal.style.display = 'flex');
close?.addEventListener('click', () => modal.style.display = 'none');

// Toggle affichage des infos pour chaque photo
document.querySelectorAll('.toggle-info').forEach(button => {
    button.addEventListener('click', () => {
        const infoDiv = button.previousElementSibling;
        infoDiv.style.display = infoDiv.style.display === 'none' ? 'block' : 'none';
    });
});
</script>

<style>
nav {
    background: #f5f5f5;
    padding: 1em;
    display: flex;
    justify-content: flex-end;
    gap: 1em;
}

.gallery {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 1em;
}

.media-item {
    width: 200px;
    text-align: center;
    position: relative;
    border: 1px solid #ddd;
    padding: 10px;
    border-radius: 8px;
}

.media-item img {
    max-width: 100%;
    border-radius: 8px;
}

.flash-success { color: green; }
.flash-error { color: red; }

/* Label "Privé" */
.label-prive {
    position: absolute;
    top: 5px;
    left: 5px;
    background: red;
    color: white;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.8em;
}

/* MODAL */
.modal {
    display: none;
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,0.5);
    justify-content: center;
    align-items: center;
    z-index: 1000;
}

.modal-content {
    background: white;
    padding: 2em;
    border-radius: 10px;
    width: 400px;
}

.modal-content input,
.modal-content select {
    width: 100%;
    margin-bottom: 10px;
    padding: 6px;
}
</style>

{% endblock %}
