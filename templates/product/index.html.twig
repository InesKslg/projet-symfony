{% extends 'base.html.twig' %}

{% block title %}Mes Photos Privées{% endblock %}

{% block body %}
<nav>
    {% if app.user %}
        <span>Bienvenue, {{ app.user.email }}</span>
        <button id="addMediaBtn" class="btn">Ajouter un post</button>
        <button id="requestThemeBtn" class="btn">Demander un nouveau thème</button>
        <button id="addAlbumBtn" class="btn">Ajouter un album</button>
        <a href="{{ path('app_logout') }}" class="btn logout">Déconnexion</a>
    {% else %}
        <a href="{{ path('app_home') }}" class="btn">Accueil</a>
    {% endif %}
</nav>

{# --- Notifications --- #}
{% if notifications|length > 0 %}
    {% set notif = notifications[0] %}
    <div class="notif-bubble" data-id="{{ notif.id }}">
        <span class="notif-icon">🔔</span>
        <span class="notif-text">{{ notif.message }}</span>
        <span class="notif-close">✖</span>
    </div>
{% endif %}

<template id="notif-template">
    <div class="notif-bubble" data-id="">
        <span class="notif-icon">🔔</span>
        <span class="notif-text"></span>
        <span class="notif-close">✖</span>
    </div>
</template>

{# Flash messages #}
{% for message in app.flashes('success') %}
    <div class="flash-success">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="flash-error">{{ message }}</div>
{% endfor %}

{# --- Onglets Photos / Albums --- #}
<div class="tabs">
    <button class="tab-btn active" data-tab="photosTab">Photos</button>
    <button class="tab-btn" data-tab="albumsTab">Albums</button>
</div>

{# --- Photos Tab --- #}
<div id="photosTab" class="tab-content" style="display:block;">
    {% if photos is empty %}
        <p>Vous n'avez aucune photo privée pour l'instant.</p>
    {% else %}
        <div class="gallery">
            {% for photo in photos %}
                <div class="media-item" data-id="{{ photo.id }}">
                    <img src="{{ asset('uploads/photos/' ~ photo.photoUrl) }}" alt="photo">
                    <p class="photo-desc">{{ photo.description }}</p>
                    <span class="label-prive">{{ photo.public ? 'Public' : 'Privé' }}</span>

                    <div class="photo-info" style="display:none; text-align:left; margin-top:5px;">
                        <p><strong>Description :</strong> {{ photo.description }}</p>
                        <p><strong>Localisation :</strong> {{ photo.localisation ?: 'Non renseignée' }}</p>
                        <p><strong>Date de prise :</strong> {{ photo.datePrise ? photo.datePrise|date('d/m/Y') : 'Non renseignée' }}</p>
                        <p><strong>Thème :</strong> {% if photo.themes|length > 0 %}{{ photo.themes|first.nom }}{% else %}Aucun{% endif %}</p>
                        <p><strong>Statut :</strong> {{ photo.public ? 'Public' : 'Privé' }}</p>

                        {# Formulaire Modifier photo #}
                        <form action="{{ path('app_edit_photo', {'id': photo.id}) }}" method="POST">
                            <input type="text" name="description" value="{{ photo.description }}" required>
                            <label><input type="checkbox" name="public" {{ photo.public ? 'checked' : '' }}> Photo publique</label>
                            <button type="submit">Modifier</button>
                        </form>

                        {# Formulaire Supprimer photo #}
                        <form action="{{ path('app_delete_photo', {'id': photo.id}) }}" method="POST" onsubmit="return confirm('Supprimer cette photo ?');">
                            <button type="submit">Supprimer</button>
                        </form>
                    </div>

                    <button class="toggle-info">Voir détails</button>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>

{# --- Albums Tab --- #}
<div id="albumsTab" class="tab-content" style="display:none;">
    {% if albums is empty %}
        <p>Vous n'avez aucun album pour l'instant.</p>
    {% else %}
        <div class="gallery">
            {% for album in albums %}
                <div class="media-item" data-id="{{ album.id }}">
                    <p><strong>{{ album.categorie }}</strong></p>
                    <span class="label-prive">{{ album.status ? 'Public' : 'Privé' }}</span>
                    
                    <div class="album-info" style="display:none; text-align:left; margin-top:5px;">
                        <p><strong>Statut :</strong> {{ album.status ? 'Public' : 'Privé' }}</p>
                        
                        <form action="{{ path('app_edit_album', {'id': album.id}) }}" method="POST">
                            <input type="text" name="categorie" value="{{ album.categorie }}" required>
                            <label><input type="checkbox" name="status" {{ album.status ? 'checked' : '' }}> Album public</label>
                            <button type="submit">Modifier</button>
                        </form>
                        
                        <form action="{{ path('app_delete_album', {'id': album.id}) }}" method="POST" onsubmit="return confirm('Supprimer cet album ?');">
                            <button type="submit">Supprimer</button>
                        </form>

                        <form action="{{ path('app_add_photo_to_album', {'id': album.id}) }}" method="POST" enctype="multipart/form-data">
                            <label>Ajouter une photo :</label>
                            <input type="file" name="photo_file" required>
                            <input type="text" name="description" placeholder="Description" required>
                            <label><input type="checkbox" name="public"> Publier en public</label>
                            <button type="submit">Ajouter</button>
                        </form>

                    </div>

                    <button class="toggle-album-info">Voir détails</button>
                    <button class="view-album-photos-btn" data-album-id="{{ album.id }}">Voir photos de l’album</button>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>

{# --- Modals --- #}
<div id="addMediaModal" class="modal">
    <div class="modal-content">
        <h2>Ajouter / Modifier une photo</h2>
        <form action="{{ path('app_upload_photo') }}" method="POST" enctype="multipart/form-data">
            <label>Photo</label>
            <input type="file" name="photo_file" accept="image/*" required>
            <label>Description</label>
            <input type="text" name="description" required>
            <label>Thème</label>
            <select name="theme_id" required>
                <option value="">-- Choisir un thème --</option>
                {% for theme in themes %}
                    <option value="{{ theme.id }}">{{ theme.nom }}</option>
                {% endfor %}
            </select>
            <label><input type="checkbox" name="public"> Publier en public</label>
            <br><br>
            <button type="submit">Publier</button>
        </form>
        <br>
        <button id="closeModal">Fermer</button>
    </div>
</div>

<div id="addAlbumModal" class="modal">
    <div class="modal-content">
        <h2>Ajouter un nouvel album</h2>
        {{ form_start(albumForm) }}
            {{ form_row(albumForm.categorie, { 'label': 'Titre / Catégorie de l’album' }) }}
            {{ form_row(albumForm.status, { 'label': 'Album public' }) }}
            <button type="submit">Créer l’album</button>
        {{ form_end(albumForm) }}
        <br>
        <button id="closeAlbumModal">Fermer</button>
    </div>
</div>

<div id="themeRequestModal" class="modal">
    <div class="modal-content">
        <h2>Demander un nouveau thème</h2>
        <div id="themeError" style="color:red; margin-bottom:10px;"></div>
        <form id="themeRequestForm">
            <label for="title">Titre</label>
            <input type="text" name="title" id="title" required>
            <label for="description">Description</label>
            <textarea name="description" id="description" required></textarea>
            <button type="submit">Envoyer la demande</button>
        </form>
        <br>
        <button id="closeThemeModal">Fermer</button>
    </div>
</div>

<div id="viewAlbumModal" class="modal">
    <div class="modal-content">
        <h2 id="modalAlbumTitle">Photos de l’album</h2>
        <div id="albumPhotosContainer" class="gallery"></div>
        <button id="closeAlbumPhotosModal">Fermer</button>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {

    // --- Onglets ---
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.style.display = 'none');
            btn.classList.add('active');
            document.getElementById(btn.dataset.tab).style.display = 'block';
        });
    });

    // --- Notifications ---
    async function loadNextNotification() {
        const response = await fetch('/notification/next');
        const data = await response.json();
        if (!data || !data.id) return;
        const template = document.querySelector('#notif-template').content.cloneNode(true);
        const bubble = template.querySelector('.notif-bubble');
        bubble.dataset.id = data.id;
        bubble.querySelector('.notif-text').textContent = data.message;
        document.body.appendChild(bubble);
        attachNotifCloseEvent();
    }
    function attachNotifCloseEvent() {
        document.querySelectorAll('.notif-close').forEach(closeBtn => {
            closeBtn.addEventListener('click', async (e) => {
                const bubble = e.target.closest('.notif-bubble');
                const id = bubble.dataset.id;
                await fetch('/notification/read/' + id);
                bubble.remove();
                loadNextNotification();
            });
        });
    }
    attachNotifCloseEvent();

    // --- Modals ---
    const modal = document.getElementById('addMediaModal');
    const btn = document.getElementById('addMediaBtn');
    const close = document.getElementById('closeModal');
    btn?.addEventListener('click', () => modal.style.display = 'flex');
    close?.addEventListener('click', () => modal.style.display = 'none');

    const albumModal = document.getElementById('addAlbumModal');
    const albumBtn = document.getElementById('addAlbumBtn');
    const closeAlbumBtn = document.getElementById('closeAlbumModal');
    albumBtn?.addEventListener('click', () => albumModal.style.display = 'flex');
    closeAlbumBtn?.addEventListener('click', () => albumModal.style.display = 'none');

    const themeModal = document.getElementById('themeRequestModal');
    const themeBtn = document.getElementById('requestThemeBtn');
    const closeThemeBtn = document.getElementById('closeThemeModal');
    const errorBox = document.getElementById('themeError');
    themeBtn?.addEventListener('click', () => {
        errorBox.textContent = "";
        themeModal.style.display = 'flex';
    });
    closeThemeBtn?.addEventListener('click', () => themeModal.style.display = 'none');

    // --- Fermer modals en cliquant dehors ---
    window.addEventListener('click', (e) => {
        [modal, albumModal, themeModal, document.getElementById('viewAlbumModal')].forEach(m => {
            if(e.target === m) m.style.display = 'none';
        });
    });

    // --- Toggle infos ---
    document.addEventListener('click', (e) => {
        if(e.target.classList.contains('toggle-info')) {
            const infoDiv = e.target.previousElementSibling;
            infoDiv.style.display = infoDiv.style.display === 'none' ? 'block' : 'none';
            e.target.innerText = infoDiv.style.display === 'none' ? 'Voir détails' : 'Voir moins';
        }

        if(e.target.classList.contains('toggle-album-info')) {
            const infoDiv = e.target.previousElementSibling;
            infoDiv.style.display = infoDiv.style.display === 'none' ? 'block' : 'none';
            e.target.innerText = infoDiv.style.display === 'none' ? 'Voir détails' : 'Voir moins';
        }

        if(e.target.classList.contains('view-album-photos-btn')) {
            (async () => {
                const albumId = e.target.dataset.albumId;
                const response = await fetch(`/album/${albumId}/json`);
                const data = await response.json();
                const container = document.getElementById('albumPhotosContainer');
                container.innerHTML = '';
                document.getElementById('modalAlbumTitle').textContent = `Photos de l’album ${data.albumName}`;
                if(data.photos.length === 0) {
                    container.innerHTML = '<p>Aucune photo dans cet album.</p>';
                } else {
                    data.photos.forEach(photo => {
                        const div = document.createElement('div');
                        div.classList.add('media-item');
                        div.innerHTML = `
                            <img src="/uploads/photos/${photo.photoUrl}" alt="photo">
                            <p class="photo-desc">${photo.description}</p>
                            <span class="label-prive">${photo.public ? 'Public' : 'Privé'}</span>
                            <form action="/photo/${photo.id}/edit" method="POST">
                                <input type="text" name="description" value="${photo.description}" required>
                                <label><input type="checkbox" name="public" ${photo.public ? 'checked' : ''}> Photo publique</label>
                                <button type="submit">Modifier</button>
                            </form>
                            <form action="/photo/${photo.id}/delete" method="POST" onsubmit="return confirm('Supprimer cette photo ?');">
                                <button type="submit">Supprimer</button>
                            </form>
                        `;
                        container.appendChild(div);
                    });
                }
                document.getElementById('viewAlbumModal').style.display = 'flex';
            })();
        }

        if(e.target.id === 'closeAlbumPhotosModal') {
            document.getElementById('viewAlbumModal').style.display = 'none';
        }
    });

});
</script>
{% endblock %}

{% block stylesheets %}
<style>
/* --- Onglets --- */
.tabs { display:flex; gap:10px; margin-top:1em; }
.tab-btn { padding:8px 16px; background:#ddd; border:none; border-radius:5px; cursor:pointer; }
.tab-btn.active { background:#333; color:white; }

/* NAV & BOUTONS */
nav { display:flex; justify-content:flex-end; gap:10px; padding:1em; background:#f5f5f5; flex-wrap:wrap; }
nav .btn { padding:6px 12px; border:none; border-radius:5px; cursor:pointer; background:#333; color:white; transition:0.3s; }
nav .btn:hover { background:#555; }
nav .logout { background:red; }

/* GALERIE */
.gallery { display:flex; flex-wrap:wrap; gap:20px; margin-top:1em; }
.media-item { width:200px; text-align:center; position:relative; border:1px solid #ddd; padding:10px; border-radius:8px; }
.media-item img { max-width:100%; border-radius:8px; }
.label-prive { position:absolute; top:5px; left:5px; background:red; color:white; padding:2px 6px; border-radius:4px; font-size:0.8em; }

/* MODAL */
.modal { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); justify-content:center; align-items:center; z-index:9999; }
.modal-content { background:white; padding:2em; border-radius:10px; width:90%; max-width:400px; }
.modal-content input, .modal-content select, .modal-content textarea, .modal-content button { width:100%; margin-bottom:10px; padding:6px; }

/* NOTIFICATIONS */
.notif-bubble { position:fixed; bottom:20px; right:20px; background:white; color:#333; padding:12px 18px; border-radius:12px; display:flex; align-items:center; gap:10px; z-index:10; box-shadow:0 4px 15px rgba(0,0,0,0.15); animation:fadeIn 0.3s ease-out; max-width:300px; }
.notif-close { cursor:pointer; font-size:1.2rem; color:#666; }
.notif-close:hover { color:#000; }

@keyframes fadeIn { from {opacity:0; transform:translateY(10px);} to {opacity:1; transform:translateY(0);} }

/* FLASH */
.flash-success { color:green; }
.flash-error { color:red; }

@media (max-width:600px) {
    .media-item { width:100%; }
    nav { flex-direction:column; align-items:flex-start; }
    .tabs { flex-direction:column; }
}
</style>
{% endblock %}