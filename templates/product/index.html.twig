{% extends 'base.html.twig' %}

{% block title %}Bienvenue{% endblock %}

{% block body %}

<nav>
    {% if app.user %}
        <span>Bienvenue, {{ app.user.email }}</span>
        <button id="addMediaBtn">Ajouter un post</button>
        <a href="{{ path('app_logout') }}">Déconnexion</a>
    {% else %}
        <a href="{{ path('app_home') }}">Accueil</a>
    {% endif %}
</nav>

{% for message in app.flashes('success') %}
    <div class="flash-success">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="flash-error">{{ message }}</div>
{% endfor %}

{% if albums is empty %}
    <p>Créez votre premier album !</p>
{% else %}
    {% for album in albums %}
        <h2>{{ album.categorie }}</h2>
        <div class="gallery">

            {% for photo in album.photos %}
                <div class="media-item">
                    <img src="{{ photo.photoUrl }}" alt="photo">
                    <p>{{ photo.description }}</p>
                </div>
            {% else %}
                <p>Aucune photo dans cet album.</p>
            {% endfor %}

            {% for video in album.videos %}
                <div class="media-item">
                    <video controls width="200">
                        <source src="{{ video.videoUrl }}" type="video/mp4">
                    </video>
                    <p>{{ video.description }}</p>
                </div>
            {% endfor %}

        </div>
    {% endfor %}
{% endif %}

<!-- MODAL -->
<div id="addMediaModal" class="modal">
    <div class="modal-content">

        <h2>Ajouter un nouveau post</h2>

        <div class="tabs">
            <button class="tab active" onclick="showTab('photoTab')">Photo</button>
            <button class="tab" onclick="showTab('videoTab')">Vidéo</button>
        </div>

        <!-- PHOTO -->
        <div id="photoTab" class="tab-content">
            <form action="{{ path('app_upload_photo') }}" method="POST">

                <label>URL Photo</label>
                <input type="text" name="photo_url" required>

                <label>Description</label>
                <input type="text" name="description" required>

                <label>
                    <input type="checkbox" name="public">
                    Public
                </label>

                <br><br>
                <button type="submit">Publier</button>

            </form>
        </div>

        <!-- VIDEO -->
        <div id="videoTab" class="tab-content" style="display:none;">
            <p>Bientôt disponible</p>
        </div>

        <button id="closeModal">Fermer</button>

    </div>
</div>

<script>
const modal = document.getElementById('addMediaModal');
const btn = document.getElementById('addMediaBtn');
const close = document.getElementById('closeModal');

btn?.addEventListener('click', () => modal.style.display = 'flex');
close?.addEventListener('click', () => modal.style.display = 'none');

function showTab(tabId) {
    document.getElementById('photoTab').style.display = 'none';
    document.getElementById('videoTab').style.display = 'none';

    document.getElementById(tabId).style.display = 'block';
}
</script>

<style>
nav {
    background:#f5f5f5;
    padding:1em;
    display:flex;
    justify-content:flex-end;
    gap:1em;
}

.gallery {
    display:flex;
    flex-wrap:wrap;
    gap:20px;
    margin-top:1em;
}

.media-item {
    width:200px;
    text-align:center;
}

.media-item img, .media-item video {
    max-width:100%;
    border-radius:8px;
}

.flash-success { color:green; }
.flash-error { color:red; }

/* MODAL */
.modal {
    display:none;
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,0.5);
    justify-content:center;
    align-items:center;
    z-index:1000;
}

.modal-content {
    background:white;
    padding:2em;
    border-radius:10px;
    width:400px;
}

.tabs {
    display:flex;
    gap:10px;
    margin-bottom:15px;
}

.tab {
    padding:8px 15px;
    cursor:pointer;
    border:none;
    background:#eee;
}

.tab.active {
    background:#ccc;
}
</style>

{% endblock %}