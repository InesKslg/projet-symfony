{% extends 'base.html.twig' %}

{% block title %}Mes Photos{% endblock %}

{% block body %}
<nav>
    {% if app.user %}
        <header class="home-header">
            <div class="logo">PIXARA</div>
        </header>
        <span>Bienvenue, {{ app.user.email }}</span>
        <button id="addMediaBtn" class="btn">Ajouter un post</button>
        <button id="requestThemeBtn" class="btn">Demander un nouveau thème</button>
        <button id="addAlbumBtn" class="btn">Ajouter un album</button>
        <a href="{{ path('app_logout') }}" class="btn logout">Déconnexion</a>
    {% else %}
        <a href="{{ path('app_home') }}" class="btn">Accueil</a>
    {% endif %}
</nav>

<!-- TABS -->
<div class="tabs">
    <button class="tab-btn active" data-tab="photosTab">Photos privées</button>
    <button class="tab-btn" data-tab="publicPhotosTab">Photos publiques</button>
    <button class="tab-btn" data-tab="albumsTab">Albums</button>
</div>

<!-- PHOTOS PRIVÉES -->
<div id="photosTab" class="tab-content">
    <div class="themes">
        <button class="theme-bubble active" data-theme="all">Tous</button>
        {% for theme in themes %}
            <button class="theme-bubble" data-theme="{{ theme.nom|lower }}">{{ theme.nom }}</button>
        {% endfor %}
    </div>
    <div class="gallery">
        {% for photo in privatePhotos %}
        <div class="media-item" data-theme="{{ photo.themes|map(t => t.nom)|join(',') }}" data-public="{{ photo.public ? 'true' : 'false' }}">
            <img src="/uploads/photos/{{ photo.photoUrl }}" alt="{{ photo.description }}">
            <p class="photo-desc">{{ photo.description }}</p>

            <div class="photo-info" style="display:none;">
                <p><strong>Description :</strong> {{ photo.description }}</p>
                <p><strong>Localisation :</strong> {{ photo.localisation ?: 'Non renseignée' }}</p>
                <p><strong>Date :</strong> {{ photo.datePrise ? photo.datePrise|date('d/m/Y') : 'Non renseignée' }}</p>
                <p><strong>Thème :</strong> {{ photo.themes|map(t => t.nom)|join(', ') }}</p>
                <p><strong>Statut :</strong> {{ photo.public ? 'Public' : 'Privé' }}</p>

                <form action="{{ path('app_edit_photo', {'id': photo.id}) }}" method="POST">
                    <input type="text" name="description" value="{{ photo.description }}" required>
                    <label><input type="checkbox" name="public" {% if photo.public %}checked{% endif %}> Photo publique</label>
                    <button type="submit">Enregistrer</button>
                </form>

                <form action="{{ path('app_delete_photo', {'id': photo.id}) }}" method="POST" onsubmit="return confirm('Supprimer cette photo ?');">
                    <button type="submit">Supprimer</button>
                </form>
            </div>

            <button class="toggle-info">Voir détails</button>
        </div>
        {% endfor %}
    </div>
</div>

<!-- PHOTOS PUBLIQUES -->
<div id="publicPhotosTab" class="tab-content" style="display:none;">
    <div class="themes">
        <button class="theme-bubble active" data-theme="all">Tous</button>
        {% for theme in themes %}
            <button class="theme-bubble" data-theme="{{ theme.nom|lower }}">{{ theme.nom }}</button>
        {% endfor %}
    </div>
    <div class="gallery">
        {% for photo in publicPhotos %}
        <div class="media-item" data-theme="{{ photo.themes|map(t => t.nom)|join(',') }}" data-public="true">
            <img src="/uploads/photos/{{ photo.photoUrl }}" alt="{{ photo.description }}">
            <p class="photo-desc">{{ photo.description }}</p>

            <div class="photo-info" style="display:none;">
                <p><strong>Description :</strong> {{ photo.description }}</p>
                <p><strong>Localisation :</strong> {{ photo.localisation ?: 'Non renseignée' }}</p>
                <p><strong>Date :</strong> {{ photo.datePrise ? photo.datePrise|date('d/m/Y') : 'Non renseignée' }}</p>
                <p><strong>Thème :</strong> {{ photo.themes|map(t => t.nom)|join(', ') }}</p>
                <p><strong>Statut :</strong> {{ photo.public ? 'Public' : 'Privé' }}</p>

                <form action="{{ path('app_delete_photo', {'id': photo.id}) }}" method="POST" onsubmit="return confirm('Supprimer cette photo ?');">
                    <button type="submit">Supprimer</button>
                </form>
            </div>

            <button class="toggle-info">Voir détails</button>
        </div>
        {% endfor %}
    </div>
</div>

<!-- ALBUMS -->
<div id="albumsTab" class="tab-content" style="display:none;">
    {% if albums is empty %}
        <p>Vous n'avez aucun album pour l'instant.</p>
    {% else %}
        <div class="gallery">
            {% for album in albums %}
                <div class="media-item" data-id="{{ album.id }}">
                    <p><strong>{{ album.categorie }}</strong></p>
                    <span class="label-prive">{{ album.status ? 'Public' : 'Privé' }}</span>

                    <div class="album-info" style="display:none; text-align:left; margin-top:5px;">
                        <p><strong>Statut :</strong> {{ album.status ? 'Public' : 'Privé' }}</p>
                        
                        <form action="{{ path('app_delete_album', {'id': album.id}) }}" method="POST" onsubmit="return confirm('Supprimer cet album ?');">
                            <button type="submit">Supprimer</button>
                        </form>

                        <form action="{{ path('app_add_photo_to_album', {'id': album.id}) }}" method="POST">
                            <p>Sélectionnez les photos privées à ajouter :</p>
                            <div class="checkbox-list" style="max-height:200px; overflow-y:auto; border:1px solid #ccc; padding:10px;">
                                {% set availablePhotos = privatePhotos|filter(p => not p.public and p.id not in album.photos|map(p => p.id)) %}
                                {% for photo in availablePhotos %}
                                    <div>
                                        <label>
                                            <input type="checkbox" name="photo_ids[]" value="{{ photo.id }}">
                                            {{ photo.description }}
                                        </label>
                                    </div>
                                {% endfor %}
                                {% if availablePhotos|length == 0 %}
                                    <p>Toutes vos photos privées sont déjà dans cet album.</p>
                                {% endif %}
                            </div>
                            <button type="submit" style="margin-top:10px;">Ajouter à l’album</button>
                        </form>
                    </div>

                    <button class="toggle-album-info">Voir détails</button>
                    <button class="view-album-photos-btn" data-album-id="{{ album.id }}">Voir photos de l’album</button>
                    
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
<!-- MODALS -->
<div id="addMediaModal" class="modal">
    <div class="modal-content">
        <h2>Ajouter / Modifier une photo</h2>
        <form action="{{ path('app_upload_photo') }}" method="POST" enctype="multipart/form-data">
            <label>Photo</label>
            <input type="file" name="photo_file" accept="image/*" required>
            <label>Description</label>
            <input type="text" name="description" required>
            <label>Thème</label>
            <select name="theme_id">
                <option value="">-- Choisir un thème --</option>
                {% for theme in themes %}
                    <option value="{{ theme.id }}">{{ theme.nom }}</option>
                {% endfor %}
            </select>
            <label><input type="checkbox" name="public"> Publier en public</label>
            <button type="submit">Publier</button>
        </form>
        <button id="closeModal">×</button>
    </div>
</div>

<div id="addAlbumModal" class="modal">
    <div class="modal-content">
        <h2>Ajouter un nouvel album</h2>
        {{ form_start(albumForm) }}
            {{ form_row(albumForm.categorie, { 'label': 'Titre / Catégorie de l’album' }) }}
            <button type="submit">Créer l’album</button>
        {{ form_end(albumForm) }}
        <button id="closeAlbumModal">×</button>
    </div>
</div>

<div id="themeRequestModal" class="modal">
    <div class="modal-content">
        <h2>Demander un nouveau thème</h2>
        <div id="themeError" style="color:red;"></div>
        <form id="themeRequestForm">
            <label for="title">Titre</label>
            <input type="text" name="title" id="title" required>
            <label for="description">Description</label>
            <textarea name="description" id="description" required></textarea>
            <button type="submit">Envoyer la demande</button>
        </form>
        <button id="closeThemeModal">×</button>
    </div>
</div>

<div id="viewAlbumModal" class="modal">
    <div class="modal-content">
        <h2 id="modalAlbumTitle">Photos de l’album</h2>
        <div id="albumPhotosContainer" class="gallery"></div>
        <button id="closeAlbumPhotosModal">×</button>
    </div>
</div>

<div id="editPhotoModal" class="modal">
    <div class="modal-content">
        <h2>Modifier la photo</h2>
        <form id="editPhotoForm">
            <input type="hidden" name="photo_id" value="">
            <label>Description</label>
            <input type="text" name="description" required>
            <label><input type="checkbox" name="public"> Photo publique</label>
            <button type="submit">Enregistrer</button>
        </form>
        <button id="closeEditPhotoModal">×</button>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {

    // --- Onglets ---
    const tabButtons = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');
    tabButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            tabButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            const tabId = btn.dataset.tab;
            tabContents.forEach(tc => {
                tc.style.display = tc.id === tabId ? 'block' : 'none';
                const themeButtons = tc.querySelectorAll('.theme-bubble');
                if(themeButtons.length){
                    themeButtons.forEach(b => b.classList.remove('active'));
                    themeButtons[0].classList.add('active');
                    const items = tc.querySelectorAll('.media-item');
                    items.forEach(i => i.style.display='block');
                }
            });
        });
    });

    // --- Filtre thèmes ---
    document.querySelectorAll('.theme-bubble').forEach(btn => {
        btn.addEventListener('click', () => {
            const parent = btn.closest('.tab-content');
            const items = parent.querySelectorAll('.media-item');
            parent.querySelectorAll('.theme-bubble').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            const selected = btn.dataset.theme.toLowerCase();
            let anyVisible = false;
            items.forEach(item => {
                const normalize = str => str.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
                const themes = item.dataset.theme.split(',').map(t => normalize(t.trim()));
                const show = selected==='all'||themes.includes(normalize(selected));
                item.style.display = show ? 'block':'none';
                if(show) anyVisible=true;
            });
            let msg = parent.querySelector('.no-photos-msg');
            if(!anyVisible){
                if(!msg){
                    msg=document.createElement('p');
                    msg.className='no-photos-msg';
                    msg.textContent='Aucune photo pour ce thème.';
                    parent.appendChild(msg);
                }
            } else if(msg){ msg.remove(); }
        });
    });

    // --- Toggle "Voir détails" pour photos ---
    document.querySelectorAll('.toggle-info').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const parent = btn.closest('.media-item');
            if (!parent) return;
            const info = parent.querySelector('.photo-info');
            if (!info) return;
            const isOpen = info.style.display === 'block';
            info.style.display = isOpen ? 'none' : 'block';
            btn.innerText = isOpen ? 'Voir détails' : 'Voir moins';
        });
    });

    // --- Toggle "Voir détails" pour albums ---
    document.querySelectorAll('.toggle-album-info').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const parent = btn.closest('.media-item');
            if (!parent) return;
            const info = parent.querySelector('.album-info');
            if (!info) return;
            const isOpen = info.style.display === 'block';
            info.style.display = isOpen ? 'none' : 'block';
            btn.innerText = isOpen ? 'Voir détails' : 'Voir moins';
        });
    });

    // --- Modals ---
    function setupModal(openId, modalId, closeId){
        const openBtn = openId ? document.getElementById(openId) : null;
        const modal = document.getElementById(modalId);
        const close = document.getElementById(closeId);
        if(openBtn) openBtn.addEventListener('click',()=>modal.style.display='flex');
        if(close) close.addEventListener('click',()=>modal.style.display='none');
    }
    setupModal('addMediaBtn','addMediaModal','closeModal');
    setupModal('addAlbumBtn','addAlbumModal','closeAlbumModal');
    setupModal('requestThemeBtn','themeRequestModal','closeThemeModal');
    setupModal(null,'editPhotoModal','closeEditPhotoModal');
    setupModal(null,'viewAlbumModal','closeAlbumPhotosModal');

    // --- Voir photos album sur la page ---
    document.querySelectorAll('.view-album-photos-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.stopPropagation();

            const albumId = btn.dataset.albumId;

            // On cherche ou on crée un conteneur sous l’album
            let container = btn.parentElement.querySelector('.album-photos-container');
            if (!container) {
                container = document.createElement('div');
                container.className = 'album-photos-container';
                container.style.display = 'flex';
                container.style.flexWrap = 'wrap';
                container.style.gap = '15px';
                container.style.marginTop = '15px';
                btn.parentElement.appendChild(container);
            }
            container.innerHTML = 'Chargement...';

            // On récupère les photos via AJAX
            fetch(`/album/${albumId}/photos`)
                .then(res => res.json())
                .then(data => {
                    container.innerHTML = ''; // on vide le "Chargement..."
                    if (data.length === 0) {
                        container.innerHTML = '<p>Aucune photo dans cet album.</p>';
                    } else {
                        data.forEach(photo => {
                            const div = document.createElement('div');
                            div.className = 'media-item';
                            div.style.width = '200px';
                            div.style.position = 'relative';
                            div.style.border = '1px solid #ddd';
                            div.style.padding = '10px';
                            div.style.borderRadius = '8px';
                            div.style.textAlign = 'center';
                            div.dataset.public = photo.public;
                            div.dataset.theme = (photo.themes || []).map(t => t.nom.toLowerCase()).join(',');

                            div.innerHTML = `
                                <img src="/uploads/photos/${photo.photoUrl}" alt="${photo.description}" style="max-width:100%; border-radius:8px;">
                                <p class="photo-desc">${photo.description}</p>
                            `;

                            const badge = document.createElement('span');
                            badge.className = 'label-prive';
                            badge.textContent = photo.public ? 'Public' : 'Privé';
                            badge.style.position = 'absolute';
                            badge.style.top = '5px';
                            badge.style.left = '5px';
                            div.appendChild(badge);
                            div.innerHTML += `
                                <form action="/photo/${photo.id}/delete" method="POST" onsubmit="return confirm('Supprimer cette photo ?');">
                                    <button type="submit" class="delete-btn">Supprimer</button>
                                </form>
                            `;

                            container.appendChild(div);
                        });
                    }
                })
                .catch(err => {
                    console.error('Erreur AJAX album:', err);
                    container.innerHTML = '<p>Erreur lors du chargement des photos.</p>';
                });
        });
    });
});
</script>
{% endblock %}

{% block stylesheets %}
<style>
/* --- GLOBAL --- */
body {
    font-family: 'Poppins', sans-serif;
    margin: 0;
    padding: 0;
}

.logo {
    font-size: 2.4rem;
    font-weight: 900;
    color: #1abc9c;
    text-transform: uppercase;
}

nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    padding: 1em;
    background: #f5f5f5;
}

.btn {
    padding: 8px 14px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    background: #1abc9c;
    color: white;
    font-weight: 600;
}

.tabs {
    display: flex;
    gap: 10px;
    margin-top: 1em;
    flex-wrap: wrap;
}

.tab-btn {
    padding: 8px 16px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    background: #ddd;
}

.tab-btn.active {
    background: #333;
    color: white;
}

.gallery {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 1em;
}

.media-item {
    width: 200px;
    position: relative;
    border: 1px solid #ddd;
    padding: 10px;
    border-radius: 8px;
    text-align: center;
}

.media-item img {
    max-width: 100%;
    border-radius: 8px;
}

.label-prive {
    position: absolute;
    top: 5px;
    left: 5px;
    background: red;
    color: white;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.8em;
}

.toggle-info,
.toggle-album-info,
.view-album-photos-btn {
    margin-top: 8px;
    padding: 6px 12px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    background: #16a085;
    color: white;
    font-weight: 600;
}

.album-info {
    display: none;
    background: #f9fafc;
    padding: 10px;
    border-radius: 8px;
    margin-top: 5px;
    text-align: left;
    font-size: 0.9rem;
}

.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(4px);
    justify-content: center;
    align-items: center;
    z-index: 9999;
    padding: 20px;
}

.modal-content {
    background: #fff;
    padding: 2.5em 2em;
    border-radius: 15px;
    width: 100%;
    max-width: 450px;
    position: relative;
    box-shadow: 0 10px 40px rgba(0,0,0,0.25);
}

.modal-content h2 {
    margin-top: 0;
    text-align: center;
    color: #1abc9c;
    margin-bottom: 1em;
}

.modal-content input,
.modal-content select,
.modal-content textarea {
    width: 100%;
    margin-bottom: 12px;
    padding: 10px 12px;
    border-radius: 8px;
    border: 1px solid #ccc;
}

.modal-content button {
    width: 100%;
    padding: 12px 0;
    border: none;
    border-radius: 10px;
    background: #1abc9c;
    color: white;
    font-weight: 600;
    cursor: pointer;
}

#closeModal,
#closeAlbumModal,
#closeThemeModal,
#closeEditPhotoModal,
#closeAlbumPhotosModal {
    position: absolute;
    top: 15px;
    right: 15px;
    width: 30px;
    height: 30px;
    background: #e74c3c;
    color: white;
    border: none;
    border-radius: 50%;
    font-size: 1.2rem;
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
}

/* Album photos horizontal scroll */
.album-photos-container {
    display: flex;
    overflow-x: auto;
    gap: 15px;
    margin-top: 15px;
    padding-bottom: 10px;
}

.album-photos-container .media-item {
    flex: 0 0 auto;
    width: 200px;
    position: relative;
    border: 1px solid #ddd;
    border-radius: 8px;
    text-align: center;
    padding: 10px;
    background: #fff;
}

.album-photos-container .media-item img {
    max-width: 100%;
    border-radius: 8px;
}

.album-photos-container .delete-btn {
    margin-top: 6px;
    padding: 6px 12px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    background-color: #e74c3c;
    color: white;
    font-weight: 600;
}

.album-photos-container .delete-btn:hover {
    background-color: #c0392b;
}

.themes {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin: 25px 0;
}

.theme-bubble {
    padding: 10px 22px;
    border-radius: 50px;
    border: 1px solid #ddd;
    cursor: pointer;
    background: white;
}

.theme-bubble.active {
    background: #1abc9c;
    color: white;
    border: none;
}

@media(max-width:768px){
    .media-item { width: 45%; }
}

@media(max-width:480px){
    .media-item { width: 100%; }
    nav { flex-direction: column; }
    .tabs { flex-direction: column; }
}

.photo-desc {
    display: inline-block;
    max-width: 10ch;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
</style>
{% endblock %}