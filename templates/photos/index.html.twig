{# ========================= #}
{# TAB PHOTOS PRIVÉES        #}
{# ========================= #}
<div id="photosTab" class="tab-content" style="display:block;">

    {% if privatePhotos is empty %}
        <p>Vous n'avez aucune photo privée.</p>
    {% else %}

        <div id="themesContainerPhotos">
            {% include 'themes/index.html.twig' with {'themes': themes} %}
        </div>

        <div class="gallery">
            {% for photo in privatePhotos %}
                <div class="media-item" 
                    data-id="{{ photo.id }}" 
                    data-public="false"
                    data-theme="{{ photo.themes|map(t => t.nom|lower)|join(',') }}">
                    
                    <img src="{{ asset('uploads/photos/' ~ photo.photoUrl) }}">
                    <p class="photo-desc">{{ photo.description }}</p>
                    <span class="label-prive">Privé</span>

                    <div class="photo-info" style="display:none;">
                        <p><strong>Description :</strong> {{ photo.description }}</p>
                        <p><strong>Localisation :</strong> {{ photo.localisation ?: 'Non renseignée' }}</p>
                        <p><strong>Date :</strong> {{ photo.datePrise ? photo.datePrise|date('d/m/Y') : 'Non renseignée' }}</p>
                    </div>

                    <button class="toggle-info">Voir détails</button>
                </div>
            {% endfor %}
        </div>

    {% endif %}
</div>


{# ========================= #}
{# TAB PHOTOS PUBLIQUES      #}
{# ========================= #}
<div id="publicPhotosTab" class="tab-content" style="display:none;">

    {% if publicPhotos is empty %}
        <p>Aucune photo publique.</p>
    {% else %}

        <div id="themesContainerPublic">
            {% include 'themes/index.html.twig' with {'themes': themes} %}
        </div>

        <div class="gallery">
            {% for photo in publicPhotos %}
                <div class="media-item"
                     data-id="{{ photo.id }}"
                     data-public="true"
                     data-theme="{{ photo.themes|map(t => t.nom|lower)|join(',') }}">

                    <img src="{{ asset('uploads/photos/' ~ photo.photoUrl) }}">
                    <p class="photo-desc">{{ photo.description }}</p>

                    <span class="label-prive">Public</span>

                    <div class="photo-info" style="display:none;">
                        <p><strong>Description :</strong> {{ photo.description }}</p>
                        <p><strong>Localisation :</strong> {{ photo.localisation ?: 'Non renseignée' }}</p>
                        <p><strong>Date :</strong> {{ photo.datePrise ? photo.datePrise|date('d/m/Y') : 'Non renseignée' }}</p>
                    </div>

                    <button class="toggle-info">Voir détails</button>
                </div>
            {% endfor %}
        </div>

    {% endif %}
</div>