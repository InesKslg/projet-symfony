<div id="albumsTab" class="tab-content" style="display:none;">
    {% if albums is empty %}
        <p>Vous n'avez aucun album pour l'instant.</p>
    {% else %}
        <div class="gallery">
            {% for album in albums %}
                <div class="media-item" data-id="{{ album.id }}">
                    
                    <p><strong>{{ album.categorie }}</strong></p>

                    <!-- Badge statut -->
                    <span class="label-prive">
                        {{ album.status ? 'Public' : 'Privé' }}
                    </span>

                    <div class="album-info">
                        <p><strong>Statut :</strong> {{ album.status ? 'Public' : 'Privé' }}</p>

                        <form action="{{ path('app_delete_album', {'id': album.id}) }}" method="POST"
                              onsubmit="return confirm('Supprimer cet album ?');">
                            <button type="submit">Supprimer</button>
                        </form>

                        <form action="{{ path('app_add_photo_to_album', {'id': album.id}) }}" method="POST">
                            <p>Sélectionnez les photos privées à ajouter :</p>

                            <div class="checkbox-list">
                                {% for photo in photos %}
                                    {% if not photo.public and photo.id not in album.photos|map(p => p.id) %}
                                        <label>
                                            <input type="checkbox" name="photo_ids[]" value="{{ photo.id }}">
                                            {{ photo.description }}
                                        </label>
                                    {% endif %}
                                {% endfor %}
                            </div>

                            <button type="submit">Ajouter à l’album</button>
                        </form>
                    </div>

                    <button class="toggle-album-info">Voir détails</button>
                    <button class="view-album-photos-btn" data-album-id="{{ album.id }}">
                        Voir photos de l’album
                    </button>

                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>